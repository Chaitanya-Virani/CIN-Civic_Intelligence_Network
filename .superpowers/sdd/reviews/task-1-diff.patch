+import { initials } from "@/lib/utils";
+
+export interface User {
+  id: string;
+  tenantId: string;
+  name: string;
+  role: string;
+  /** the constituency this user belongs to (department / ward) */
+  constituency: string;
+  avatarInitials: string;
+}
+
+function u(
+  id: string,
+  tenantId: string,
+  name: string,
+  role: string,
+  constituency: string,
+): User {
+  return { id, tenantId, name, role, constituency, avatarInitials: initials(name) };
+}
+
